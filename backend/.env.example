# Backend environment variables — copy this file to `.env` and fill in real values.

# SQLite database location (Prisma)
DATABASE_URL="file:./prisma/dev.db"

# Secret used to sign JWT tokens. MUST be set, otherwise the server refuses to start.
# Generate a strong random value, e.g.:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"

# Port the API server listens on
PORT=3001

# Admin account password used by the seed script (prisma/seed.ts).
# If not set, the seed falls back to "admin@123".
ADMIN_PASSWORD="admin@123"
